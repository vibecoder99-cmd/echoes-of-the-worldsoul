+// ---------------------------------------------------------------------------
+// World script — periodic stat refresh every 10 seconds
+// Picks up mid-session attunements without requiring a relog.
+// ---------------------------------------------------------------------------
+
+class AttunementPlusWorldScript : public WorldScript
+{
+public:
+    AttunementPlusWorldScript() : WorldScript("AttunementPlusWorldScript") {}
+
+    void OnUpdate(uint32 /*diff*/) override
+    {
+        uint32 now = getMSTime();
+        if (now - _lastUpdate < 10000) return;
+        _lastUpdate = now;
+
+        WorldSessionMgr::SessionMap const& sessions = sWorldSessionMgr->GetAllSessions();
+        for (auto const& [accountId, session] : sessions)
+        {
+            if (!session) continue;
+            Player* player = session->GetPlayer();
+            if (!player || !player->IsInWorld()) continue;
+
+            // Patch any equipped+attuned items whose snapshot armor is still 0
+            PatchEquippedItemArmor(player);
+
+            float newStats[7] = { 0.0f };
+            CalculateAbsorption(player, newStats);
+
+            uint32 guid = player->GetGUID().GetCounter();
+            auto it = g_appliedStats.find(guid);
+
+            bool changed = (it == g_appliedStats.end());
+            if (!changed)
+            {
+                for (int i = 0; i < 7; ++i)
+                {
+                    if (std::abs(std::floor(newStats[i]) - it->second[i]) > 0.5f)
+                    {
+                        changed = true;
+                        break;
+                    }
+                }
+            }
+
+            if (changed)
+            {
+                ApplyAttunementStats(player, true);
+                LOG_INFO("module", "[EotW] Periodic refresh for {}: STR={:.0f} AGI={:.0f} STA={:.0f} INT={:.0f} SPI={:.0f} ARMOR={:.0f} WDPS={:.0f}",
+                    player->GetName(), newStats[0], newStats[1], newStats[2], newStats[3], newStats[4], newStats[5], newStats[6]);
+            }
+        }
+    }
+
+private:
+    uint32 _lastUpdate = 0;
+};
+
+// ---------------------------------------------------------------------------
+// Unit script — per-hit life leech
+// ---------------------------------------------------------------------------
+
+class AttunementPlusUnitScript : public UnitScript
+{
+public:
+    AttunementPlusUnitScript() : UnitScript("AttunementPlusUnitScript") {}
+
+    // Fires for every damage event in the world; filter to player-on-creature only
+    void OnDamage(Unit* attacker, Unit* victim, uint32& damage) override
+    {
+        if (!attacker || !victim || damage == 0)
+            return;
+        if (!attacker->IsPlayer() || !victim->IsCreature())
+            return;
+
+        Player* player = attacker->ToPlayer();
+        // Gray check: creature more than 10 levels below player
+        if (victim->GetLevel() + 10 < player->GetLevel())
+            return;
+
+        uint32 accountId = player->GetSession()->GetAccountId();
+        auto&  cache     = GetSinkCached(accountId);
+
+        // Life Leech: restore HP proportional to damage dealt
+        if (cache.leechInvested > 0.0)
+        {
+            double leechFrac = ApSinkEffect(0.08, 0.000005, cache.leechInvested);
+            if (leechFrac > 0.0)
+            {
+                uint32 healAmount = static_cast<uint32>(std::max(1.0, std::floor(damage * leechFrac)));
+                uint32 curHP      = player->GetHealth();
+                uint32 maxHP      = player->GetMaxHealth();
+                if (curHP < maxHP)
+                {
+                    uint32 actualHeal = std::min(healAmount, maxHP - curHP);
+                    if (actualHeal > 0)
+                    {
+                        player->SetHealth(curHP + actualHeal);
+                        NotifyLeechThrottled(player, actualHeal);
+                    }
+                }
+            }
+        }
+
+        // Execute Power: bonus damage when target is below 20% HP
+        // Intentionally runs after leech so leech reads base damage; execute then amplifies
+        if (cache.executePowerInvested > 0.0 && victim->GetHealthPct() < 20.0f)
+        {
+            double exBonus = ApSinkEffect(0.40, 0.000003, cache.executePowerInvested);
+            if (exBonus > 0.0)
+            {
+                uint32 extraDmg = static_cast<uint32>(std::floor(damage * exBonus));
+                damage += extraDmg;
+            }
+        }
+
+        // Armor Penetration: compensate for armor already applied by inflating post-mitigation damage.
+        // Derives how much armor reduced the hit, then partially reverses that reduction.
+        // armorConstant = 467.5 * 80 - 22167.5 = 15232.5, valid for level-80 attackers only.
+        if (cache.armorPenInvested > 0.0 && damage > 0)
+        {
+            double armorPenFrac = ApSinkEffect(0.30, 0.000003, cache.armorPenInvested);
+            if (armorPenFrac > 0.0)
+            {
+                float targetArmor = static_cast<float>(victim->GetArmor());
+                if (targetArmor > 0.0f)
+                {
+                    float reductionFrac  = targetArmor / (targetArmor + 15232.5f);
+                    float penOfReduction = static_cast<float>(armorPenFrac) * reductionFrac;
+                    if (penOfReduction < 1.0f)
+                    {
+                        float dmgMult = 1.0f / (1.0f - penOfReduction);
+                        uint32 newDamage = static_cast<uint32>(std::floor(damage * dmgMult));
+                        if (newDamage > damage)
+                            damage = newDamage;
+                    }
+                }
+            }
+        }
+    }
+
+    // Fires for every spell damage event; filter to player targets only
+    void ModifySpellDamageTaken(Unit* target, Unit* attacker, int32& damage, SpellInfo const* spellInfo) override
+    {
+        if (!target || !target->IsPlayer() || damage <= 0)
+            return;
+        // nullptr spellInfo = physical auto-attack; skip all non-spell damage
+        if (!spellInfo)
+            return;
+        // Skip physical school (SPELL_SCHOOL_MASK_NORMAL = 1)
+        if (spellInfo->GetSchoolMask() == SPELL_SCHOOL_MASK_NORMAL)
+            return;
+
+        Player* player   = target->ToPlayer();
+        uint32 accountId = player->GetSession()->GetAccountId();
+        auto& cache = GetSinkCached(accountId);
+
+        // Spell Mitigation
+        double mitigInvested = cache.mitigInvested;
+        if (mitigInvested > 0.0)
+        {
+            double mitigFrac = ApSinkEffect(0.25, 0.000004, mitigInvested);
+            if (mitigFrac > 0.0)
+            {
+                uint32 reduction = static_cast<uint32>(std::floor(static_cast<double>(damage) * mitigFrac));
+                // Never reduce to zero from mitigation alone
+                if (reduction >= static_cast<uint32>(damage))
+                    reduction = static_cast<uint32>(damage) - 1;
+                damage -= static_cast<int32>(reduction);
+                NotifyMitigationThrottled(player, reduction);
+            }
+        }
+
+        // Reflect Chance: small chance to reflect spell damage back to the attacker
+        double refInvested = cache.reflectInvested;
+        if (refInvested > 0.0 && damage > 0 && attacker && attacker != target)
+        {
+            double reflectFrac = ApSinkEffect(0.05, 0.000002, refInvested);
+            if (reflectFrac > 0.0)
+            {
+                uint32 roll      = urand(0, 9999);
+                uint32 threshold = static_cast<uint32>(reflectFrac * 10000.0);
+
+                if (roll < threshold)
+                {
+                    uint32 reflectDamage = static_cast<uint32>(damage);
+                    damage = 0;
+
+                    Unit::DealDamage(attacker, attacker, reflectDamage, nullptr,
+                        DIRECT_DAMAGE, SPELL_SCHOOL_MASK_NORMAL, nullptr, false);
+
+                    NotifyReflectThrottled(player, reflectDamage);
+                }
+            }
+        }
+    }
+};
+
+// ---------------------------------------------------------------------------
+// Module registration
+// ---------------------------------------------------------------------------
+
+void AddSC_mod_attunement_plus()
+{
+    new AttunementPlusPlayerScript();
+    new AttunementPlusWorldScript();
+    new AttunementPlusUnitScript();
+}

