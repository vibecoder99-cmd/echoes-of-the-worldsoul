+// ---------------------------------------------------------------------------
+// Player script — handles login/logout/level/equip events
+// ---------------------------------------------------------------------------
+
+class AttunementPlusPlayerScript : public PlayerScript
+{
+public:
+    AttunementPlusPlayerScript() : PlayerScript("AttunementPlusPlayerScript") {}
+
+    void OnPlayerLogin(Player* player) override
+    {
+        // Delay stat application so Lua's login migration (snapshot capture)
+        // completes first. Both run on the same login event; Lua may run after us.
+        uint32 guid = player->GetGUID().GetCounter();
+        player->m_Events.AddEventAtOffset([guid]()
+        {
+            Player* p = ObjectAccessor::FindPlayerByLowGUID(guid);
+            if (p && p->IsInWorld())
+                ApplyAttunementStats(p, true);
+        }, Milliseconds(3000));
+    }
+
+    void OnPlayerLogout(Player* player) override
+    {
+        ApplyAttunementStats(player, false);
+    }
+
+    // Re-apply on level change (absorption scales with level)
+    void OnPlayerLevelChanged(Player* player, uint8 /*oldlevel*/) override
+    {
+        ApplyAttunementStats(player, true);
+    }
+
+    // Re-apply when gear is equipped (snapshot may have changed)
+    void OnPlayerEquip(Player* player, Item* /*it*/, uint8 /*bag*/, uint8 /*slot*/, bool /*update*/) override
+    {
+        ApplyAttunementStats(player, true);
+    }
+
+};
+
+// ---------------------------------------------------------------------------
+// Equipped-item armor patcher
+// For attuned items whose snapshot has armor=0, compute the real armor using
+// the same logic as Player::_ApplyItemBonuses:
+//   1. If the item has ScalingStatValue, look up armor from ScalingStatValuesStore
+//      at the player's current level (WotLK dynamic items).
+//   2. Otherwise use proto->Armor adjusted by ArmorDamageModifier.
+// Runs in the 10-second WorldScript tick so it self-heals on first login.
+// ---------------------------------------------------------------------------
+static const uint8 AP_EQUIP_SLOTS[] = {
+    EQUIPMENT_SLOT_HEAD,    EQUIPMENT_SLOT_NECK,       EQUIPMENT_SLOT_SHOULDERS,
+    EQUIPMENT_SLOT_CHEST,   EQUIPMENT_SLOT_WAIST,      EQUIPMENT_SLOT_LEGS,
+    EQUIPMENT_SLOT_FEET,    EQUIPMENT_SLOT_WRISTS,     EQUIPMENT_SLOT_HANDS,
+    EQUIPMENT_SLOT_FINGER1, EQUIPMENT_SLOT_FINGER2,    EQUIPMENT_SLOT_TRINKET1,
+    EQUIPMENT_SLOT_TRINKET2,EQUIPMENT_SLOT_BACK,       EQUIPMENT_SLOT_MAINHAND,
+    EQUIPMENT_SLOT_OFFHAND, EQUIPMENT_SLOT_RANGED,
+};
+
+static void PatchEquippedItemArmor(Player* player)
+{
+    uint32 guid      = player->GetGUID().GetCounter();
+    uint32 accountId = GetAccountId(guid);
+    uint8  level     = player->GetLevel();
+
+    for (uint8 slot : AP_EQUIP_SLOTS)
+    {
+        Item* item = player->GetItemByPos(INVENTORY_SLOT_BAG_0, slot);
+        if (!item) continue;
+
+        uint32 itemEntry = item->GetEntry();
+
+        // Must be attuned by this character
+        QueryResult attunedRes = CharacterDatabase.Query(
+            "SELECT 1 FROM `ap_item_attune` WHERE `guid` = {} AND `item_entry` = {} AND `attuned` = 1",
+            guid, itemEntry);
+        if (!attunedRes) continue;
+
+        // Only patch if the snapshot armor is still 0
+        QueryResult snapRes = CharacterDatabase.Query(
+            "SELECT `armor` FROM `ap_item_snapshot` WHERE `guid` = {} AND `item_entry` = {}",
+            accountId, itemEntry);
+        if (!snapRes) continue;
+        if ((*snapRes)[0].Get<float>() > 0.0f) continue;
+
+        ItemTemplate const* proto = item->GetTemplate();
+        if (!proto) continue;
+
+        // Replicate _ApplyItemBonuses armor calculation
+        uint32 armor = proto->Armor;
+        ScalingStatValuesEntry const* ssv =
+            proto->ScalingStatValue ? sScalingStatValuesStore.LookupEntry(level) : nullptr;
+        if (ssv)
+        {
+            if (uint32 ssvArmor = ssv->getArmorMod(proto->ScalingStatValue))
+                if (proto->ScalingStatValue > 0 || ssvArmor < proto->Armor)
+                    armor = ssvArmor;
+        }
+        else if (armor && proto->ArmorDamageModifier)
+        {
+            armor -= uint32(proto->ArmorDamageModifier);
+        }
+
+        // ArmorDamageModifier > 0 is added separately as TOTAL_VALUE bonus
+        float totalArmor = static_cast<float>(armor);
+        if (proto->ArmorDamageModifier > 0.0f)
+            totalArmor += proto->ArmorDamageModifier;
+
+        if (totalArmor <= 0.0f) continue;
+
+        CharacterDatabase.Execute(
+            "UPDATE `ap_item_snapshot` SET `armor` = {} WHERE `guid` = {} AND `item_entry` = {}",
+            totalArmor, accountId, itemEntry);
+
+        LOG_INFO("module", "[EotW] Patched armor for entry={} player={}: armor={:.0f} (ssv={})",
+            itemEntry, player->GetName(), totalArmor, ssv ? 1 : 0);
+    }
+}
