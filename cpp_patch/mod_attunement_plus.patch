+static constexpr uint32 AP_THREAT_REDUCTION_SPELL_ID = 900001;
+
+// Stat indices matching our Lua system
+// 0=STR, 1=AGI, 2=STA, 3=INT, 4=SPI
+static const Stats AP_STATS[5] = {
+    STAT_STRENGTH,
+    STAT_AGILITY,
+    STAT_STAMINA,
+    STAT_INTELLECT,
+    STAT_SPIRIT
+};
+
+// Adjacent-tier armor range each class can wear.
+// Allows attuning one tier below and up to the class max.
+// WoW class IDs: 1=Warrior, 2=Paladin, 3=Hunter, 4=Rogue, 5=Priest,
+//                6=DK, 7=Shaman, 8=Mage, 9=Warlock, 11=Druid
+// Subclass values: 1=cloth, 2=leather, 3=mail, 4=plate
+struct ArmorRange { int min; int max; };
+static const ArmorRange CLASS_ARMOR_RANGE[12] = {
+    {0, 0},  // 0 = unused
+    {3, 4},  // 1 = Warrior:      mail + plate
+    {3, 4},  // 2 = Paladin:      mail + plate
+    {2, 3},  // 3 = Hunter:       leather + mail
+    {1, 2},  // 4 = Rogue:        cloth + leather
+    {1, 1},  // 5 = Priest:       cloth only
+    {3, 4},  // 6 = Death Knight: mail + plate
+    {2, 3},  // 7 = Shaman:       leather + mail
+    {1, 1},  // 8 = Mage:         cloth only
+    {1, 1},  // 9 = Warlock:      cloth only
+    {0, 0},  // 10 = unused
+    {1, 2},  // 11 = Druid:       cloth + leather
+};
